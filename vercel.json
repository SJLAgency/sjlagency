{
  "name": "sjlagency",
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "css/*", "use": "@vercel/static" },
    { "src": "js/*", "use": "@vercel/static" },
    { "src": "images/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/life-insurance", "dest": "/life-insurance.html" },
    { "src": "/annuities", "dest": "/annuities.html" },
    { "src": "/disability-insurance", "dest": "/disability-insurance.html" },
    { "src": "/long-term-care", "dest": "/long-term-care.html" },
    { "src": "/about", "dest": "/about.html" },
    { "src": "/contact", "dest": "/contact.html" },
    { "src": "/compare-quotes", "dest": "/compare-quotes.html" },
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" }
  ]
}
